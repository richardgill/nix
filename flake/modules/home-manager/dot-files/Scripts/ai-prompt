#!/usr/bin/env bash
# ai-prompt: Run a prompt through an LLM with retries and timeout
# Usage: ai-prompt "your prompt here"
#    or: echo "your prompt" | ai-prompt

set -euo pipefail

TIMEOUT_SECS="${AI_PROMPT_TIMEOUT:-30}"
MAX_RETRIES="${AI_PROMPT_RETRIES:-3}"
MODEL="${AI_PROMPT_MODEL:-gpt-5.1-codex-mini}"

# Read prompt from argument or stdin
if [[ $# -gt 0 && "$1" != "-" ]]; then
  PROMPT="$1"
else
  PROMPT=$(cat)
fi

[[ -z "$PROMPT" ]] && { echo "Error: No prompt provided" >&2; exit 1; }

run_prompt() {
  local stdout_file stderr_file exit_code
  stdout_file=$(mktemp)
  stderr_file=$(mktemp)

  if timeout "$TIMEOUT_SECS" codex exec -m "$MODEL" "$PROMPT" >"$stdout_file" 2>"$stderr_file"; then
    exit_code=0
  else
    exit_code=$?
  fi

  if [ "$exit_code" -eq 0 ]; then
    cat "$stdout_file"
    rm -f "$stdout_file" "$stderr_file"
    return 0
  fi

  cat "$stderr_file" >&2
  if [ ! -s "$stderr_file" ]; then
    cat "$stdout_file" >&2
  fi
  echo "Error: codex exec failed with exit code $exit_code" >&2
  rm -f "$stdout_file" "$stderr_file"
  return 1
}

for attempt in $(seq 1 "$MAX_RETRIES"); do
  if result=$(run_prompt); then
    echo "$result"
    exit 0
  fi
  [[ $attempt -lt $MAX_RETRIES ]] && sleep 1
done

echo "Error: Failed after $MAX_RETRIES attempts" >&2
exit 1

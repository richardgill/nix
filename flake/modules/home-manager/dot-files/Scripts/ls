#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source ~/Scripts/lib/ai-agent
path_no_self="$(awk -v RS=':' -v ORS=':' -v self="$script_dir" 'length($0) && $0 != self { print }' <<< "$PATH")"
path_no_self="${path_no_self%:}"
real_ls="$(PATH="$path_no_self" command -v ls || true)"

if [ -z "$real_ls" ]; then
  echo "ls not found on PATH (outside $script_dir)" >&2
  exit 1
fi

# AI agent: resolve symlinks only.
if is_ai_agent; then
  exec "$real_ls" -L "$@"
fi

# Human use: keep color and one-entry-per-line.
ls_args=(--color=auto -1)
exec "$real_ls" "${ls_args[@]}" "$@"

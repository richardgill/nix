#!/usr/bin/env bash
set -euo pipefail

app_name="${1:-}"

if [[ -z "$app_name" ]]; then
  echo "Usage: check-webapp-open <app-name>"
  exit 1
fi

niri msg --json windows \
  | jq -e --arg app "$app_name" '.. | objects | select(has("app_id")) | select((.app_id // "") | test("chrome-app\\." + $app))' \
  > /dev/null
